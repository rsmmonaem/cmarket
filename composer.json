{
    "name": "nibiz/cmarket",
    "description": "E-commerce + Wallet + Affiliate + Investment Ecosystem",
    "type": "project",
    "require": {
        "php": "^8.2",
        "barryvdh/laravel-dompdf": "^3.1",
        "intervention/image": "^3.11",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.0",
        "maatwebsite/excel": "^3.1",
        "nwidart/laravel-modules": "^12.0",
        "spatie/laravel-permission": "^6.0"
    },
    "require-dev": {
        "laravel/installer": "^5.24"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Modules\\Admin\\": "Modules/Admin/app/",
            "Modules\\Merchant\\": "Modules/Merchant/app/",
            "Modules\\Customer\\": "Modules/Customer/app/",
            "Modules\\Affiliate\\": "Modules/Affiliate/app/",
            "Modules\\Rider\\": "Modules/Rider/app/",
            "Modules\\Ecommerce\\": "Modules/Ecommerce/app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "wikimedia/composer-merge-plugin": true,
            "nwidart/laravel-modules": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}